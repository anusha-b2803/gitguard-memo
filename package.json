{
  "name": "gitguard-memo",
  "displayName": "GitGuard & Memo",
  "description": "Professional branch protection and contextual commit memo management for secure development workflows.",
  "version": "1.0.1",
  "license": "MIT",
  "publisher": "AnushaB",
  "author": "Anusha B",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/anusha-b2803/gitguard-memo"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:gitguard.memoView",
    "onCommand:gitguard.addToMemo"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitguard.addToMemo",
        "title": "Add to Commit Memo",
        "category": "GitGuard"
      },
      {
        "command": "gitguard.clearMemo",
        "title": "Clear Memo",
        "category": "GitGuard"
      },
      {
        "command": "gitguard.configure",
        "title": "Configure Branch rules",
        "category": "GitGuard"
      },
      {
        "command": "gitguard.viewMemo",
        "title": "View Current Memo",
        "category": "GitGuard"
      },
      {
        "command": "gitguard.deleteMemoItem",
        "title": "Delete Memo Item",
        "icon": "$(trash)"
      },
      {
        "command": "gitguard.previewMemoItem",
        "title": "Preview Memo Item"
      },
      {
        "command": "gitguard.insertAndCommit",
        "title": "Insert & Commit",
        "icon": "$(add)"
      },
      {
        "command": "gitguard.repairGit",
        "title": "Repair Git Workflow (Fix Checkout Errors)",
        "category": "GitGuard"
      },
      {
        "command": "gitguard.editMemoItem",
        "title": "Edit Memo",
        "icon": "$(pencil)"
      },
      {
        "command": "gitguard.moveMemoUp",
        "title": "Move Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "gitguard.moveMemoDown",
        "title": "Move Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "gitguard.toggleMemoPin",
        "title": "Pin/Unpin Memo",
        "icon": "$(pin)"
      },
      {
        "command": "gitguard.refreshMemos",
        "title": "Refresh Memos",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "gitguard.insertAndCommit",
          "when": "view == gitguard.memoView",
          "group": "inline@1"
        },
        {
          "command": "gitguard.moveMemoUp",
          "when": "view == gitguard.memoView",
          "group": "inline@2"
        },
        {
          "command": "gitguard.moveMemoDown",
          "when": "view == gitguard.memoView",
          "group": "inline@3"
        },
        {
          "command": "gitguard.toggleMemoPin",
          "when": "view == gitguard.memoView",
          "group": "inline@4"
        },
        {
          "command": "gitguard.editMemoItem",
          "when": "view == gitguard.memoView",
          "group": "inline@5"
        },
        {
          "command": "gitguard.deleteMemoItem",
          "when": "view == gitguard.memoView",
          "group": "inline@6"
        }
      ],
      "view/title": [
        {
          "command": "gitguard.refreshMemos",
          "when": "view == gitguard.memoView",
          "group": "navigation"
        },
        {
          "command": "gitguard.clearMemo",
          "when": "view == gitguard.memoView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "gitguard.addToMemo",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "scm": [
        {
          "id": "gitguard.memoView",
          "name": "Commit Memos"
        }
      ]
    },
    "configuration": {
      "title": "GitGuard & Memo",
      "properties": {
        "gitguard.branchRules": {
          "type": "array",
          "default": [
            {
              "pattern": "^(main|master|prod)$",
              "backgroundColor": "#8b0000",
              "foregroundColor": "#ffffff"
            },
            {
              "pattern": "^(hotfix/.*|release/.*)$",
              "backgroundColor": "#ffbf00",
              "foregroundColor": "#000000"
            }
          ],
          "description": "Rules for branch visual styling. Matching pattern uses Regex."
        },
        "gitguard.storageMode": {
          "type": "string",
          "default": "global",
          "enum": [
            "global",
            "workspace"
          ],
          "enumDescriptions": [
            "Store colors in User Profile (Invisible to Git, supports all branches)",
            "Store colors in .vscode/settings.json (Causes Git conflicts if tracked)"
          ],
          "description": "Where to store UI color customizations. 'global' is recommended to avoid Git errors."
        },
        "gitguard.ignoredRepositories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of repository root paths to ignore (No colors will be applied)."
        },
        "gitguard.autoPopulateCommit": {
          "type": "boolean",
          "default": true,
          "description": "Automatically populate the Git commit input box with memo items."
        },
        "gitguard.autoDeleteMemosAfterCommit": {
          "type": "boolean",
          "default": false,
          "description": "Automatically remove a memo item from the list after a successful 'Insert & Commit'."
        },
        "gitguard.colorTargets": {
          "type": "array",
          "default": [
            "statusBar",
            "titleBar",
            "activityBar",
            "tabBar",
            "breadcrumb"
          ],
          "description": "Which UI zones to colorize based on branch rules.",
          "items": {
            "type": "string",
            "enum": [
              "statusBar",
              "titleBar",
              "activityBar",
              "tabBar",
              "breadcrumb"
            ],
            "enumDescriptions": [
              "Bottom status bar",
              "Top title/menu bar",
              "Left activity/icon bar",
              "Editor tab bar (navbar)",
              "Breadcrumb navigation bar"
            ]
          }
        }
      }
    }
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@types/node": "16.x",
    "typescript": "^4.7.4",
    "eslint": "^8.18.0"
  }
}